<?xml version="1.0" encoding="utf-8" ?>
<?xaml-comp compile="true" ?>

<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeApp2025.Resources.Styles.LightTheme">

    <Color x:Key="BackgroundColor">#F1FAF0</Color>
    <Color x:Key="PrimaryColor">#D0E0D0</Color>
    <Color x:Key="AccentColor">#4DC9C0</Color>
    <Color x:Key="TextColor">#0F4C4A</Color>


    <Style x:Key="ButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentColor}" />
        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
        <Setter Property="BorderColor" Value="{StaticResource TextColor}"/>
        <Setter Property="BorderWidth" Value="0"/>
    </Style>

</ResourceDictionary>
    