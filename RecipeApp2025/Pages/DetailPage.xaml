<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="RecipeApp2025.Pages.DetailPage"
             Padding="0">
    <ScrollView Padding="0">
        <VerticalStackLayout
            Spacing="10"
             Padding="0"
            VerticalOptions="Start">

            <VerticalStackLayout
                Spacing="-37">

                <Image Source="{Binding Large_img_url}"
                        VerticalOptions="Fill"
                        WidthRequest="400"
                        />

                <Grid
                    RowDefinitions="*, *">
                    <Label
                       Text="{Binding Name}"
                       HorizontalOptions="Center"
                       FontSize="Title"
                       HorizontalTextAlignment="Center"
                       />
                    <Grid 
                            Grid.Row="1"
                            ColumnDefinitions=".33*, .33*, .33*"
                            Padding="10">
                        <Label Grid.Column="0"
                                   Text="{Binding Total_time, StringFormat='Ready in {0}m'}"
                                   FontSize="Default"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>

                        <Label  Grid.Column="1"
                                Text="{Binding Num_people_served, StringFormat='Serves {0}'}"
                                FontSize="Default"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                        <Button 
                                    x:Name="ToggleButton"
                                    Text="Save"
                                    Clicked="OnToggleButtonClicked"
                                    Grid.Column="2"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>

                    </Grid>
                    <Grid.Background>
                        <LinearGradientBrush EndPoint=".5,.2"
                             StartPoint="0.5,0">
                            
                            <GradientStop Color="Transparent"
                                Offset=".1" />
                            <GradientStop Color="White"
                                Offset="1" />
                        </LinearGradientBrush>

                    </Grid.Background>
                </Grid>

            </VerticalStackLayout>


            <Grid
                ColumnDefinitions=".5*, .5*">
                <Label
                       Padding="10,0,10,0"
                       Text="{Binding Prep_time, StringFormat='Prep Time {0}m'}"
                       FontSize="Subtitle"
                    HorizontalOptions="Center"/>

                <Label
                       Padding="10,0,10,0"
                       Text="{Binding Cook_time, StringFormat='Cook Time {0}m'}"
                       FontSize="Subtitle"
                    Grid.Column="1"
                    HorizontalOptions="Center"/>
            </Grid>
