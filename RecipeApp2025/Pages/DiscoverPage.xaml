<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="RecipeApp2025.Pages.DiscoverPage">

    <ListView x:Name="DiscoverFeed"
                  SeparatorColor="Transparent"
                  HasUnevenRows="True"
                  SelectionMode="None"
                  ItemAppearing="OnItemAppearing"
                  Margin="10">
        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell>
                    <Border Padding="5"
                            BackgroundColor="White"
                            Stroke="Black"
                            StrokeThickness="1">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                    Command="{Binding BindingContext.GoToRecipeDetailPageCommand, Source={x:Reference DiscoverFeed}}"
                                    CommandParameter="{Binding .}"
                                    />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="40" />
                        </Border.StrokeShape>
                        <Grid Padding="1"
                              ColumnSpacing="15"
                              RowSpacing="10"
                              RowDefinitions="Auto, Auto, Auto"
                              ColumnDefinitions="1*, 3*, 1*">

                            <Border Grid.RowSpan="3"
                                   Grid.Column="0"
                                   HeightRequest="90"
                                   WidthRequest="70"
                                   BackgroundColor="Transparent"
                                   Padding="0"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="30" />
                                </Border.StrokeShape>
                                <Image Source="{Binding Img_url}"
                                       Aspect="AspectFill"/>
                            </Border>

                            <StackLayout Grid.Row="0"
                                         Grid.Column="1"
                                         HorizontalOptions="End"
                                         VerticalOptions="Start"
                                         Spacing="5">
                                <Label Text="{Binding Name}"
                                       FontSize="Title"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"
                                       HorizontalOptions="FillAndExpand"/>
                            </StackLayout>

                            <StackLayout Grid.Row="1"
                                         Grid.Column="1"
                                         HorizontalOptions="End"
                                         VerticalOptions="Center"
                                         Orientation="Horizontal"
                                         Spacing="5">
                                <Image Source="tine.png"
                                       WidthRequest="20"
                                       HeightRequest="20"/>
                                <Label Text="{Binding Total_time, StringFormat='{0} minutes'}"
                                       FontSize="Medium"
                                       VerticalOptions="Center"/>
                            </StackLayout>

                            <StackLayout Grid.Row="2"
                                         Grid.Column="1"
                                         HorizontalOptions="End"
                                         VerticalOptions="Center"
                                         Orientation="Horizontal"
                                         Spacing="5">
                                <Image Source="person.png"
                                       WidthRequest="20"
                                       HeightRequest="20"/>
                                <Label Text="{Binding Num_people_served, StringFormat='{0}'}"
                                       FontSize="Medium"
                                       VerticalOptions="Center"/>
                            </StackLayout>
                        </Grid>

                    </Border>

                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>

    </ListView>
</ContentPage>
