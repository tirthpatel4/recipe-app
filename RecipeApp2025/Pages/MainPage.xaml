<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="RecipeApp2025.Pages.MainPage">


    <ScrollView>
        <Grid RowDefinitions="auto, auto"
              ColumnDefinitions=".85*, .15*"
              Padding="21"
              RowSpacing="40"
              ColumnSpacing="10">

            <Border
                Grid.Row="0"
                Grid.Column="0"
                StrokeThickness="5"
                Padding="5"
     >
                <Entry Placeholder="Search for Recipes"
                       PlaceholderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}"
                       FontAttributes="Italic"/>
            </Border>

            <Button
                    Text="Go"
                    BackgroundColor="#708090"
                    Grid.Row="0"
                    Grid.Column="1"
                    CornerRadius="10"
                
                />

            <StackLayout
                Grid.Row="1"
                Grid.ColumnSpan="2"
                x:Name="ButtonStackLayout"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Margin="10"
                Spacing="50">
                <Button
                    Text="Discover"
                    FontSize="50"
                    BackgroundColor="#708090"
                    FontAttributes="Bold"
                    HeightRequest="100"
                    CornerRadius="20"
                    Clicked="OnDiscoverButtonClicked">
                </Button>

                <Button
                    Text="Saved Recipes"
                    FontAttributes="Bold"
                    BackgroundColor="#708090"
                    TextColor="white"
                    CornerRadius="20"
                    HeightRequest="100"
                    FontSize="30"
                    Clicked="OnSavedRecipesButtonClicked">
                </Button>
            </StackLayout>
        </Grid>
    </ScrollView>
</ContentPage>